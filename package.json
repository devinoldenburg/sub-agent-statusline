{
  "name": "opencode-subagent-statusline",
  "version": "0.8.0",
  "description": "Production-ready OpenCode TUI plugin for subagent session status",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/devinoldenburg/sub-agent-statusline"
  },
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": ">=22.13"
  },
  "main": "./dist/tui.js",
  "types": "./dist/tui.d.ts",
  "exports": {
    ".": {
      "types": "./dist/tui.d.ts",
      "import": "./dist/tui.js"
    },
    "./tui": {
      "types": "./dist/tui.d.ts",
      "import": "./dist/tui.js"
    },
    "./runtime": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "assets",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "prepack": "pnpm run build",
    "release": "semantic-release",
    "audit:prod": "pnpm audit --prod --audit-level moderate",
    "pack:dry-run": "pnpm pack --dry-run",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check:no-emoji": "tsx scripts/assert-no-emoji.ts README.md docs src SECURITY.md CONTRIBUTING.md CHANGELOG.md",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "dev": "tsup --watch"
  },
  "keywords": [
    "opencode",
    "plugin",
    "statusline",
    "subagent"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.14.50 <2",
    "@opentui/core": ">=0.2.10 <0.4",
    "@opentui/solid": ">=0.2.10 <0.4",
    "solid-js": ">=1.9.12 <2"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.14.50",
    "@opentui/core": "^0.2.10",
    "@opentui/solid": "^0.2.10",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/github": "^11.0.6",
    "@semantic-release/npm": "^12.0.2",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/node": "^22.15.21",
    "@vitest/coverage-v8": "^4.1.5",
    "esbuild-plugin-solid": "^0.6.0",
    "semantic-release": "^24.2.9",
    "tsx": "^4.20.6",
    "tsup": "^8.5.1",
    "typescript": "^5.8.3",
    "vitest": "^4.1.5"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/npm",
      "@semantic-release/github"
    ]
  }
}
